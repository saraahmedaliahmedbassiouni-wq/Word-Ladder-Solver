import nltk
from nltk.corpus import words
from collections import deque
import string
from tkinter import *
from tkinter import messagebox

try:
    words_list = words.words()
except LookupError:
    nltk.download('words')
    words_list = words.words()


# Download NLTK words corpus
nltk.download('words')

# Extract words from the file words
words_list = words.words()

# Function to filter words depending on given length and make it lower case
def filter_words(length):
    return set(
        word.lower() for word in words_list 
        if len(word) == length
    )

def getOneLetterDifferent(start_word, dictionary):
    oneLetterDifferent = []
    for i in range(len(start_word)):
        for c in string.ascii_lowercase:
            if c != start_word[i]:
                new_word = start_word[:i] + c + start_word[i+1:]
                if new_word in dictionary:
                   oneLetterDifferent.append(new_word)
    return oneLetterDifferent

def bfs(start, end, dictionary):
    queue = deque([(start, [start])])
    visited = set([start])

    while queue:
        current, path = queue.popleft()
        if current == end:
            return path
        for i in getOneLetterDifferent(current, dictionary):
            if i not in visited:
                visited.add(i)
                queue.append((i, path+[i]))

    return None

def help():
    messagebox.showinfo(title="Help",message="This is a Word Ladder Solver.\n\nEnter a start and target word of the same length.\nClick 'Find Word Ladder' to compute a transformation path.\n for example:\ncold -> wold -> word -> ward -> warm  ")

def validate_inputs(x, y):
    x_has_space = ' ' in x
    y_has_space = ' ' in y
    x_not_alpha = not x.isalpha()
    y_not_alpha = not y.isalpha()
    
    if x_has_space and y_has_space:
        messagebox.showerror(title="ERROR!!",message="Both words contain spaces! \nPlease enter single words without spaces.")
        return False
    elif x_has_space:
        messagebox.showerror(title="ERROR!!",message="Start word contains spaces! \nPlease enter a single word without spaces.")
        return False
    elif y_has_space:
        messagebox.showerror(title="ERROR!!",message="Target word contains spaces! \nPlease enter a single word without spaces.")
        return False
    
    if x_not_alpha and y_not_alpha:
        messagebox.showerror(title="ERROR!!",message="Both words contain invalid characters! \nPlease use only letters a-z.")
        return False
    elif x_not_alpha:
        messagebox.showerror(title="ERROR!!",message="Start word contains invalid characters! \nPlease use only letters a-z.")
        return False
    elif y_not_alpha:
        messagebox.showerror(title="ERROR!!",message="Target word contains invalid characters! \nPlease use only letters a-z.")
        return False
    return True

def submit():
    x = start_word.get().lower()
    y = target_word.get().lower()

    if not x and not y:
       messagebox.showerror(title= "ERROR!!",message= "Both fields are empty! Please enter two words!")
       return
    
    if not x:
        messagebox.showerror(title="ERROR!!",message= "Start word field is empty! Please enter a start word!")
        return

    if not y:
        messagebox.showerror(title="ERROR!!",message= "Target word field is empty! Please enter a target word!")
        return
    if not validate_inputs(x, y):
        return

    if len(x) != len(y):
        messagebox.showerror(title="ERROR!!",
                             message="Start and target words must be the same length.")
        return

    if x == y:
        messagebox.showerror(title="ERROR!!",
                             message="The words must be different!")
        return
    
    words_len = len(x)
    new_words = filter_words(words_len)

    if x not in new_words or y not in new_words:
        messagebox.showerror(title="ERROR!!",
                             message="One or both words not found in dictionary!")
        return

    solution_path = bfs(x, y, new_words)

    output_display.config(state=NORMAL)  # Temporarily enable editing to update content
    output_display.delete("1.0", END)
    if solution_path:
        output_display.insert(END, "Solution Path:\n\n")
        output_display.insert(END, " -> ".join(solution_path))
        output_display.insert(END, f"\n\nTotal Steps to the target: {len(solution_path)-1}")
    else:
        output_display.insert(END, "No path found between the words! \nPlease try again with different words!")
    output_display.config(state=DISABLED)  # Make it read-only again

def reset():
    start_word.delete(0, END)
    target_word.delete(0, END)
    output_display.config(state=NORMAL)  # Temporarily enable editing to clear content
    output_display.delete("1.0", END)
    output_display.insert(END, "Solution will appear here...")
    output_display.config(state=DISABLED)  # Make it read-only again

